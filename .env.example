# docker-compose calistirmadan once .env olarak kopyala ve doldur.
# Uretmek icin:
#   JWT_SECRET=$(openssl rand -hex 32)
#   IOT_API_KEY=$(openssl rand -hex 24)
#   AUTH_PASSWORD_HASH=$(python -c 'import bcrypt; print(bcrypt.hashpw(b"parolaniz", bcrypt.gensalt()).decode())')

# --- Frontend kullanici girisi (JWT) ---
JWT_SECRET=
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=
JWT_EXPIRE_MINUTES=60

# --- IoT cihaz authentication ---
IOT_API_KEY=

# --- CORS ---
# Local docker-compose icin frontend container'i host 8080 portundan servis ediyor.
ALLOWED_ORIGINS=http://localhost:8080
